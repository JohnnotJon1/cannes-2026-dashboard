{
  "manifest_version": 3,
  "name": "Cannes 2026 RSVP Auto-Fill",
  "version": "0.2.0",
  "description": "Auto-fills your name, email, company, and title on Cannes Lions 2026 RSVP forms. Nothing leaves your browser.",
  "permissions": ["storage", "scripting"],
  "host_permissions": [
    "http://localhost:3000/*",
    "http://localhost:3100/*",
    "https://cannes.airpost.ai/*",
    "https://cannes-2026-dashboard.vercel.app/*",
    "https://www.canneslions.com/*",
    "https://cannes.dentsu.com/*",
    "https://www.sportbeach.com/*",
    "https://pinterestcannes.com/*",
    "https://www.freewheelcannes.com/*",
    "https://event.adweek.com/*",
    "https://www.thefemalequotient.com/*",
    "https://cannes.propellergroup.com/*",
    "https://events.tubi.tv/*",
    "https://adage.com/*",
    "https://cannes.byspotify.com/*",
    "https://advertising.amazon.com/*",
    "https://havascafe.havas.com/*",
    "https://snapchatcannes.com/*",
    "https://tiktokatcannes.com/*",
    "https://redditforbusiness.com/*",
    "https://public.canva.site/*",
    "https://digiday.com/*",
    "https://www.campaignlive.com/*",
    "https://www.fastcompany.com/*",
    "https://ahoyclub.com/*",
    "https://bespokeyachtcharter.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Cannes 2026 RSVP Auto-Fill",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:3100/*",
        "http://localhost:3000/*",
        "https://cannes.airpost.ai/*",
        "https://cannes-2026-dashboard.vercel.app/*"
      ],
      "js": ["dashboard-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["playbook.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
