# Vercel KV — required for the /submit + /admin flow.
# After creating the KV database in the Vercel dashboard
# (Storage → Create Database → KV), these 4 variables are
# injected automatically into every environment. You only need
# to populate them locally if you want to run /submit on `npm run dev`.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=

# Random secret that grants access to /admin?token=...
# Pick a 32-char random string and set in Vercel → Settings →
# Environment Variables. Do NOT commit a real value to git.
ADMIN_TOKEN=

# Optional: used by /scripts/* only — not by the deployed app.
APIFY_TOKEN=
OPENAI_API_KEY=
