# Vercel KV — required for the /submit + /admin flow.
# After creating the KV database in the Vercel dashboard
# (Storage → Create Database → KV), these 4 variables are
# injected automatically into every environment. You only need
# to populate them locally if you want to run /submit on `npm run dev`.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=

# Random secret that grants access to /admin?token=...
# Pick a 32-char random string and set in Vercel → Settings →
# Environment Variables. Do NOT commit a real value to git.
ADMIN_TOKEN=

# Feature flag: set to "false" on the public LinkedIn-facing deploy
# to hide the events grid + Events nav item. Defaults to true so omitting
# the var leaves the full dashboard intact. NEXT_PUBLIC_ prefix is
# required because client components read this value.
NEXT_PUBLIC_SHOW_EVENTS=true

# Absolute URL of this deployment, used by OG meta tags. If unset, falls
# back to the canonical private URL. Set per-project so og:url and the
# absolute og:image URL match the domain visitors see.
NEXT_PUBLIC_SITE_URL=https://cannes-2026-dashboard.vercel.app

# Optional: used by /scripts/* only — not by the deployed app.
APIFY_TOKEN=
OPENAI_API_KEY=
